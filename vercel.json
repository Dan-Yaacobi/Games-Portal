{
  "routes": [
    { "src": "^/api/(.*)", "dest": "api/index.js" },
    { "src": "^/(auth|user|games|economy|wubble-web)(/.*)?$", "dest": "api/index.js" },
    { "src": "^/health$", "dest": "api/index.js" },
    { "src": "^/assets/(.*)$", "dest": "frontend/dist/assets/$1" },
    { "src": "^/(favicon\\.ico|vite\\.svg)$", "dest": "frontend/dist/$1" },
    { "src": "^(.*)$", "dest": "frontend/dist/index.html" }
  ]
}
